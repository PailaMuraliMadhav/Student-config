server:
  port: 8001

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/appointment_db?createDatabaseIfNotExist=true
    username: root
    password: Murali#13
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
